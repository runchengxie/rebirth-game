{
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "check": "npm run lint:ci && npm run typecheck && npm run test:run && npm run validate:frontend && npm run validate:stability && npm run validate:brand && npm run build && npm run validate:bundle",
    "lint": "eslint .",
    "lint:ci": "eslint . --max-warnings=0",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest",
    "test:run": "vitest run",
    "e2e:prepare": "npm install --no-save --no-package-lock @playwright/test@1.55.0 @axe-core/playwright@4.10.2 && npx playwright install chromium",
    "test:e2e": "playwright test --config scripts/playwright.config.js",
    "typecheck": "tsc -b",
    "validate:frontend": "node scripts/validate_frontend.js",
    "validate:stability": "node scripts/validate_stability.js",
    "dump:2023": "node scripts/content-dumps/dump2023.mjs",
    "dump:2024": "node scripts/content-dumps/dump2024.mjs",
    "dump:content": "npm run dump:2023 && npm run dump:2024",
    "validate:brand": "node scripts/validate_brand_refs.mjs",
    "validate:bundle": "node scripts/validate_bundle_size.mjs"
  },
  "dependencies": {
    "@drincs/pixi-vn": "^1.8.22",
    "pixi.js": "^8.19.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
